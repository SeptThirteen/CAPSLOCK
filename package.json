{
  "name": "capslock",
  "version": "1.0.0",
  "description": "Remap Caps Lock to any key, combo, or macro with per-application profiles",
  "main": "src/main/index.js",
  "scripts": {
    "start": "env -u ELECTRON_RUN_AS_NODE electron .",
    "build": "electron-builder --win --x64",
    "dev": "env -u ELECTRON_RUN_AS_NODE electron . --inspect=5858"
  },
  "dependencies": {
    "electron-store": "^8.1.0",
    "koffi": "^2.15.1",
    "uiohook-napi": "^1.5.4"
  },
  "devDependencies": {
    "electron": "28.3.0",
    "electron-builder": "^24.13.3"
  }
}
